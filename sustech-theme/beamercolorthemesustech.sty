% beamercolorthemesustech.sty
% Theme author: 杨昊波 (Haobo Yang) — 2026 届计算机系博士 · github.com/yhbcode000 · yhbcode000@foxmail.com
% COLOR-ONLY theme recoloring Madrid. Use on top of Madrid:
%     \usetheme{Madrid}
%     \usecolortheme{sustech}
%
% 调色板（学术风 低饱和蓝 + 橙/金 强调 + 灰绿/浅灰 辅助 + 白底）
%   主色 蓝   #2C5F7C / #3A6F8C / #5B8FA8 —— 标题结构、section、框架、主图表
%   强调 橙金 #E67E22 / #F4B942           —— 关键词、结论、重要数字
%   辅色 灰绿/浅灰 #7C9A92 / #EAECEF / #F5F7F8 —— 背景区块、辅助信息
%   背景 白   #FFFFFF
%   正文 深灰 #323236
\ProvidesPackage{beamercolorthemesustech}[2026/06/25 SUSTech academic palette for Madrid]

\RequirePackage{xcolor}

% --- 调色板 ------------------------------------------------------------------
% 主色：蓝
\definecolor{sustechblue}{HTML}{2C5F7C}    % 深青蓝（主标题 / 主结构）
\definecolor{sustechblue2}{HTML}{3A6F8C}   % 标准学术蓝（结构线 / 层级）
\definecolor{sustechblue3}{HTML}{5B8FA8}   % 柔和蓝（辅助图表）
\definecolor{sustechbluelt}{HTML}{D6E2EA}  % 极浅蓝（深底上的副标题文字）
% 强调：橙 / 金
\definecolor{sustechorange}{HTML}{E67E22}  % 学术橙（主强调）
\definecolor{sustechgold}{HTML}{F4B942}    % 柔和金黄（次强调 / highlight）
\definecolor{sustechorlt}{HTML}{FBEBDA}    % 浅橙底（强调块体）
% 辅色：灰绿 / 浅灰
\definecolor{sustechgreen}{HTML}{7C9A92}   % 灰绿（冷静辅助）
\definecolor{cardgrey}{HTML}{EAECEF}       % 浅灰（分割 / 卡片背景）
\definecolor{bgsoft}{HTML}{F5F7F8}         % 更浅背景灰（区块层次）
% 中性文字
\definecolor{sustechink}{HTML}{323236}     % 正文深灰
\definecolor{sustechgrey}{HTML}{787880}    % 次级文字灰

% --- 基础 --------------------------------------------------------------------
\setbeamercolor{normal text}{fg=sustechink,bg=white}
\setbeamercolor{structure}{fg=sustechblue}       % 结构默认走主蓝
\setbeamercolor{alerted text}{fg=sustechorange}
\setbeamercolor{example text}{fg=sustechgreen}

% --- Madrid 页脚 / 页眉三段色块（蓝色渐变：深 -> 标准 -> 柔和）----------------
\setbeamercolor{palette primary}{fg=white,bg=sustechblue}
\setbeamercolor{palette secondary}{fg=white,bg=sustechblue2}
\setbeamercolor{palette tertiary}{fg=white,bg=sustechblue3}
\setbeamercolor{palette quaternary}{fg=white,bg=sustechblue}
\setbeamercolor{author in head/foot}{fg=white,bg=sustechblue}
\setbeamercolor{title in head/foot}{fg=white,bg=sustechblue2}
\setbeamercolor{date in head/foot}{fg=white,bg=sustechblue3}

% --- 标题 / frametitle（主蓝结构）-------------------------------------------
\setbeamercolor{title}{fg=white,bg=sustechblue}
\setbeamercolor{subtitle}{fg=sustechbluelt}
\setbeamercolor{frametitle}{fg=white,bg=sustechblue}
\setbeamercolor{framesubtitle}{fg=sustechorange}

% --- 章节 / Part 标题（主蓝）------------------------------------------------
\setbeamercolor{section title}{fg=sustechblue}
\setbeamercolor{part title}{fg=sustechblue}
\setbeamercolor{section in toc}{fg=sustechink}

% --- 列表标记 / 编号（橙色强调）---------------------------------------------
\setbeamercolor{itemize item}{fg=sustechorange}
\setbeamercolor{itemize subitem}{fg=sustechorange}
\setbeamercolor{itemize subsubitem}{fg=sustechgrey}
\setbeamercolor{enumerate item}{fg=sustechorange}
\setbeamercolor{enumerate subitem}{fg=sustechorange}

% --- 块 ----------------------------------------------------------------------
% 普通 block：标准学术蓝标题（结构），极浅灰底
\setbeamercolor{block title}{fg=white,bg=sustechblue2}
\setbeamercolor{block body}{fg=sustechink,bg=bgsoft}
% alertblock（callout 要点框）：橙标题（强调），浅橙底
\setbeamercolor{block title alerted}{fg=white,bg=sustechorange}
\setbeamercolor{block body alerted}{fg=sustechink,bg=sustechorlt}
% exampleblock：灰绿标题（辅助），浅灰底
\setbeamercolor{block title example}{fg=white,bg=sustechgreen}
\setbeamercolor{block body example}{fg=sustechink,bg=cardgrey}

% --- 图注 --------------------------------------------------------------------
\setbeamercolor{caption name}{fg=sustechorange}

\mode<all>
