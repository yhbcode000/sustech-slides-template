% beamerthemesustech.sty
% =============================================================================
% 可复用 SUSTech Beamer 主题（在标准 Madrid 主题之上重新配色 + 排版宏）。
%
% Theme author / 主题作者：杨昊波 (Haobo Yang) — 2026 届计算机系博士
%   Email : yhbcode000@foxmail.com
%   GitHub: github.com/yhbcode000
% 欢迎自由使用与修改；保留此署名即可。
%
% 用法（配合本文件夹同级的 latexmkrc 把 ./sustech-theme// 加入 TEXINPUTS）：
%     \documentclass[aspectratio=169,10pt]{ctexbeamer}
%     \usetheme{sustech}
%     ... 正文 ...
%
% 提供：
%   - 学术配色（低饱和蓝主色 + 橙/金强调 + 灰绿/浅灰辅助 + 白底深灰）
%   - 排版宏 \shl \keyword \brandemph \hlbox \fitfigure \figcap \metric
%   - 环境 callout，表格辅助 \theadrow \altrow \thc，分区宽度 \zone*
%   - 含“一句话主旨”的章节分隔页（配 \secblurb 使用）
%   - 作者 credit 信息宏 \creditauthor/\creditgithub/\creditemail（不自动渲染）
% =============================================================================
\ProvidesPackage{beamerthemesustech}[2026/06/25 SUSTech reusable theme (Madrid-based)]

\mode<presentation>

% 基础布局：标准 Madrid
\usetheme{Madrid}
\setbeamertemplate{navigation symbols}{}

% 重新配色（学术调色板）
\usecolortheme{sustech}

% 排版宏与章节分隔页
\RequirePackage{beamerthemesustech-elements}

% --- 主题自带 logo -----------------------------------------------------------
% logo 随主题打包在 sustech-theme/assets/，并把该目录追加到图片搜索路径
% （在文档开始时追加，避免被正文里的 \graphicspath 覆盖）。
\RequirePackage{graphicx}
\makeatletter
\AtBeginDocument{%
  \g@addto@macro\Ginput@path{{sustech-theme/assets/}}%
}
\makeatother
% logo 路径宏（可在正文用 \renewcommand{\sustechlogo}{...} 覆盖）
\providecommand{\sustechlogo}{sustech_logo}
% 默认把 logo 作为标题页 \titlegraphic（用户仍可在正文重设 \titlegraphic 覆盖）
\titlegraphic{\includegraphics[height=0.18\paperheight,keepaspectratio]{\sustechlogo}}

% --- 主题作者 credit 宏（默认 杨昊波，可 \setcredit* 覆盖）--------------
% 仅定义信息宏，不强制渲染到每页；如需展示可自行放到标题页 / 页脚。
\newcommand{\creditauthor}{杨昊波 (Haobo Yang) — 2026 届计算机系博士}
\newcommand{\creditgithub}{github.com/yhbcode000}
\newcommand{\creditemail}{yhbcode000@foxmail.com}
\newcommand{\setcreditauthor}[1]{\renewcommand{\creditauthor}{#1}}
\newcommand{\setcreditgithub}[1]{\renewcommand{\creditgithub}{#1}}
\newcommand{\setcreditemail}[1]{\renewcommand{\creditemail}{#1}}

% --- 汇报地点 venue（默认空；用户可在正文用 \setvenue{...} 覆盖）-----------
% 配合 \datewithvenue 使用：地点非空时自动以 “·” 连接到日期之后。
\newcommand{\presvenue}{}
\newcommand{\setvenue}[1]{\renewcommand{\presvenue}{#1}}
% 把日期与地点组合成 \date 内容（地点为空则只显示日期）。
\newcommand{\datewithvenue}[1]{%
  \date{#1\ifdefempty{\presvenue}{}{ \textperiodcentered\ \presvenue}}%
}

% --- 标题页“论文出处”行 paperfrom ------------------------------------------
% 把“讲者单位”与“论文所发表的期刊/会议”在视觉与语义上分开，避免被误读为同一主体。
% 用法：\institute[短名]{讲者单位 \paperfrom{期刊 / 会议}{年份}}
%   渲染：单位另起一行，下方加“[论文来源] 〈斜体期刊〉 · 年份”小字。
\newcommand{\paperfrom}[2]{%
  \par\smallskip
  {\footnotesize\itshape\color{emph} #1}%
  {\footnotesize\color{sustechgrey}\ \textperiodcentered\ #2}%
}

% --- 标题页字段：汇报人 / 论文领域 / 论文来源 -------------------------------
% 语义约定（新版标题页）：
%   \title    中文主标题        \subtitle 英文副标题
%   \author   论文全部作者      \institute 团队所属单位
%   \setsource{期刊}{年份}      论文来源（可选）
%   \setdomains{...}            论文所属领域列表（用 \domaintag 包裹各项）
%   \setpresenter{} \setvenue{} \date{}  →  底部“汇报人 · 地点 · 时间”
\newcommand{\presenter}{}
\newcommand{\setpresenter}[1]{\renewcommand{\presenter}{#1}}
\newcommand{\paperdomains}{}
\newcommand{\setdomains}[1]{\renewcommand{\paperdomains}{#1}}
% 单个领域标签（浅灰底 + 蓝字小药丸）
\newcommand{\domaintag}[1]{\colorbox{cardgrey}{\small\color{sustechblue2}\strut\,#1\,}\hspace{0.35em}}
% 论文来源（可选）：\setsource{期刊 / 会议}{年份}
\newcommand{\papersourceinfo}{}
\newcommand{\setsource}[2]{\renewcommand{\papersourceinfo}{\paperfrom{#1}{#2}}}
% 底部信息行：汇报人 · 地点 · 时间
\newcommand{\metasep}{\hspace{0.7em}\textperiodcentered\hspace{0.7em}}
\newcommand{\titlemetaline}{%
  \ifdefempty{\presenter}{}{汇报人：\presenter\metasep}%
  \ifdefempty{\presvenue}{}{\presvenue\metasep}%
  \insertdate}

% --- 自定义标题页模板 --------------------------------------------------------
% 结构：标题/副标题 → 论文全部作者 → 团队所属单位 →（论文来源）→ 领域 →
%       汇报人·地点·时间 → logo
\setbeamertemplate{title page}{%
  \centering
  \vfill
  \begin{beamercolorbox}[wd=0.92\paperwidth,sep=12pt,center,rounded=true,shadow=true]{title}
    {\usebeamerfont{title}\inserttitle\par}%
    \ifx\insertsubtitle\@empty\else
      \vskip0.45em
      {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}%
    \fi
  \end{beamercolorbox}%
  \vskip1.1em
  {\usebeamerfont{author}\insertauthor\par}%
  \vskip0.3em
  {\usebeamerfont{institute}\usebeamercolor[fg]{institute}\insertinstitute\par}%
  \ifdefempty{\papersourceinfo}{}{\papersourceinfo\par}%
  \vskip0.9em
  \ifdefempty{\paperdomains}{}{\paperdomains\par\vskip0.9em}%
  {\small\color{sustechgrey}\titlemetaline\par}%
  \vskip1.0em
  {\inserttitlegraphic\par}%
  \vfill
}

\mode<all>
